{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "segments": [
                {
                    "foreground": "#e7c91e",
                    "style": "plain",
                    "template": "{{ .UserName }}",
                    "type": "session"
                },
                {
                    "foreground": "#e7c91e",
                    "style": "plain",
                    "template": "@",
                    "type": "text"
                },
                {
                    "foreground": "#e7c91e",
                    "style": "plain",
                    "template": "{{ .HostName }}",
                    "type": "text"
                },
                {
                    "foreground": "#2fff52",
                    "options": {
                        "style": "folder"
                    },
                    "style": "plain",
                    "template": " {{ .Path }}",
                    "type": "path"
                },
                {
                    "foreground": "#26ddfd",
                    "options": {
                        "branch_icon": ""
                    },
                    "style": "plain",
                    "template": " <#DDB15F>git(</>{{ .HEAD }}<#DDB15F>)</>",
                    "type": "git"
                },
                {
                    "foreground": "#DCB977",
                    "style": "plain",
                    "template": " \uf119",
                    "type": "status"
                }
            ],
            "type": "prompt"
        }
    ],
    "final_space": true,
    "version": 4
}