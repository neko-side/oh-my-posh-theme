{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "segments": [
                {
                    "foreground": "#40e71e",
                    "options": {
                        "style": "folder"
                    },
                    "style": "plain",
                    "template": "{{ .Path }}",
                    "type": "path"
                },
                {
                    "foreground": "#f3f3f3",
                    "style": "plain",
                    "template": ">",
                    "type": "text"
                },
                {
                    "foreground": "#26ddfd",
                    "options": {
                        "branch_icon": ""
                    },
                    "style": "plain",
                    "template": " ({{ .HEAD }})",
                    "type": "git"
                },
                {
                    "foreground": "#ff0b03",
                    "style": "plain",
                    "template": " {{ if .Segments.Git.UpstreamGone }}{{ else if gt .Code 0 }}{{ else }}{{ end }} ",
                    "type": "status"
                }
            ],
            "type": "prompt"
        }
    ],
    "final_space": true,
    "version": 4
}